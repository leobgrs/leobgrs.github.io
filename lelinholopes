<html> 
  <head>
    <base href="https://leobgrs.github.io/">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lelinho Lopes: Deputado Estadual - Trajetória e Propostas</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <style>
      :root {
        --primary-color: #e30613; /* Vermelho PT */
        --secondary-color: #ffffff;
        --accent-color: #ffcc00; /* Amarelo para detalhes */
        --text-color: #333333;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: 'Roboto', sans-serif;
        background-color: #f4f4f4;
        background-image: linear-gradient(135deg, #e30613 0%, #a3040d 100%);
        background-attachment: fixed;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        padding: 20px;
      }

      .game-header {
        background-color: var(--secondary-color);
        color: var(--primary-color);
        padding: 20px;
        text-align: center;
        border-radius: 10px 10px 0 0;
        margin-bottom: 20px;
        border-bottom: 5px solid var(--accent-color);
      }

      .game-header h2 {
        font-size: 1.8em;
        margin-bottom: 10px;
        text-transform: uppercase;
      }

      .profile-image-container {
        text-align: center;
        margin-bottom: 30px;
      }

      .profile-image {
        max-width: 100%;
        height: auto;
        border-radius: 15px;
        box-shadow: 0 8px 16px rgba(0,0,0,0.3);
        width: 500px;
        border: 4px solid white;
      }

      .game-container {
        background-color: rgba(255, 255, 255, 0.95);
        border-radius: 15px;
        box-shadow: 0 0 30px rgba(0, 0, 0, 0.4);
        padding: 30px;
        max-width: 800px;
        width: 100%;
        margin: 0 auto;
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
      }

      h1 {
        color: var(--primary-color);
        margin-bottom: 20px;
        font-size: 2.2em;
        text-align: center;
      }

      .question-area {
        margin-bottom: 20px;
        background-color: #fff3f3;
        padding: 20px;
        border-left: 5px solid var(--primary-color);
        border-radius: 8px;
        width: 100%;
      }

      .question {
        font-size: 1.3em;
        font-weight: bold;
        color: var(--text-color);
      }

      .options-container {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 15px;
        width: 100%;
      }

      .option-button {
        background-color: var(--primary-color);
        border: none;
        border-radius: 8px;
        color: white;
        cursor: pointer; 
        font-size: 1.1em;
        padding: 18px;
        transition: 0.3s;
        font-weight: bold;
      }

      .option-button:hover {
        background-color: #b3050f;
        transform: translateY(-3px);
      }

      .score {
        margin-top: 20px;
        font-size: 1.2em;
        font-weight: bold;
        color: var(--primary-color);
      }

      footer {
        text-align: center;
        padding: 20px;
        background-color: white;
        color: var(--primary-color);
        font-size: 0.9em;
        margin-top: 20px;
        border-radius: 10px;
        font-weight: bold;
      }

      .whatsapp-button {
        position: fixed;
        bottom: 20px;
        right: 20px;
        background-color: #25D366;
        color: white;
        border-radius: 50%;
        width: 60px;
        height: 60px;
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 30px;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
        text-decoration: none;
        z-index: 1000;
      }

      @media (max-width: 600px) {
        .options-container { grid-template-columns: 1fr; }
        h1 { font-size: 1.6em; }
      }
    </style>
  </head>
<body>

  <header class="game-header">
    <h2>Lelinho Lopes: A Voz de Bagé na Assembleia</h2>
    <p>O Vereador Mais Votado da História Quer Fazer Mais pelo RS!</p>
  </header>

  <div class="profile-image-container">
    <img src="lelinho_venceu.jpg" alt="Lelinho Lopes - Vereador mais votado da história de Bagé" class="profile-image">
  </div>

  <div class="game-container">
    <h1>Desafio: Você conhece o Lelinho?</h1>
    <div class="question-area">
      <p class="question" id="question">Carregando desafio...</p>
    </div>
    <div class="options-container" id="options-container"></div>
    <div class="score" id="score">Pontuação: 0</div>
    <div id="message" style="margin-top: 10px; font-weight: bold;"></div>
  </div>

  <footer>
    <p>Campanha Lelinho Lopes - Deputado Estadual</p>
    <p>Desenvolvido por Leonardo Goulart Lopes | (53) 99942-7999</p>
  </footer>

  <a href="https://wa.me/5553999427999" class="whatsapp-button" target="_blank">
    <i class="fab fa-whatsapp"></i>
  </a>

  <script>
    const questions = [
      {
        question: "Qual marca histórica Lelinho Lopes atingiu na última eleição em Bagé?",
        options: ["Vereador mais votado da história", "Prefeito mais jovem", "Secretário de Saúde", "Deputado mais votado"],
        correctAnswer: "Vereador mais votado da história"
      },
      {
        question: "A qual partido político Lelinho Lopes é filiado?",
        options: ["PT", "PL", "MDB", "PSDB"],
        correctAnswer: "PT"
      },
      {
        question: "Qual é o número de Lelinho para Deputado Estadual (Exemplo)?",
        options: ["13800", "13123", "22222", "15000"],
        correctAnswer: "13800"
      },
      {
        question: "Qual área de atuação tem sido o forte do trabalho de Lelinho em Bagé?",
        options: ["Saúde e Social", "Indústria", "Privatizações", "Agronegócio"],
        correctAnswer: "Saúde e Social"
      },
      {
        question: "Lelinho Lopes propõe levar para a Assembleia Legislativa a experiência de:",
        options: ["Fiscalização e defesa do povo", "Aumento de impostos", "Criação de novos cargos", "Venda de estatais"],
        correctAnswer: "Fiscalização e defesa do povo"
      }
    ];

    let availableQuestions = [];
    let currentQuestion = null;
    let score = 0;

    function startQuiz() {
      availableQuestions = [...questions];
      score = 0;
      document.getElementById('score').textContent = `Pontuação: ${score}`;
      newQuestion();
    }

    function newQuestion() {
      if (availableQuestions.length === 0) {
        showFinalMessage();
        return;
      }
      const index = Math.floor(Math.random() * availableQuestions.length);
      currentQuestion = availableQuestions.splice(index, 1)[0];
      
      document.getElementById('question').textContent = currentQuestion.question;
      const container = document.getElementById('options-container');
      container.innerHTML = '';
      document.getElementById('message').textContent = '';

      currentQuestion.options.forEach(opt => {
        const btn = document.createElement('button');
        btn.textContent = opt;
        btn.className = 'option-button';
        btn.onclick = () => check(opt, btn);
        container.appendChild(btn);
      });
    }

    function check(selected, btn) {
      const allBtns = document.querySelectorAll('.option-button');
      allBtns.forEach(b => b.disabled = true);

      if (selected === currentQuestion.correctAnswer) {
        score++;
        btn.style.backgroundColor = "#2ecc71";
        document.getElementById('message').textContent = "Correto! É o Lelinho com o povo!";
        document.getElementById('message').style.color = "#2ecc71";
      } else {
        btn.style.backgroundColor = "#e74c3c";
        document.getElementById('message').textContent = `A resposta correta era: ${currentQuestion.correctAnswer}`;
        document.getElementById('message').style.color = "#e74c3c";
      }
      
      document.getElementById('score').textContent = `Pontuação: ${score}`;
      setTimeout(newQuestion, 2000);
    }

    function showFinalMessage() {
      document.getElementById('question').innerHTML = `
        <div style="text-align: center;">
          <h2 style="color: var(--primary-color)">Obrigado pelo apoio!</h2>
          <p>Você conhece bem a trajetória de Lelinho Lopes. No Rio Grande, ele é a nossa voz!</p>
          <br>
          <h1 style="font-size: 3em; color: var(--primary-color); animation: pulse 1s infinite;">VOTE 13800!</h1>
          <br>
          <button onclick="location.reload()" style="padding: 10px 20px; cursor: pointer;">Refazer Desafio</button>
        </div>
      `;
      document.getElementById('options-container').innerHTML = '';
    }

    window.onload = startQuiz;
  </script>
</body>
</html>
